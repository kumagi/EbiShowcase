package main

var Time float
var Flash float

func Fragment(position vec4, texCoord vec2, color vec4) vec4 {
	c := imageSrc0At(texCoord)
	wave := 0.5 + 0.5*sin(Time)
	palette := vec3(0.45+0.55*wave, 0.5+0.4*(1.0-wave), 1.0)
	flash := vec3(Flash, Flash, Flash)
	return vec4(c.rgb*palette+flash, c.a) * color
}
